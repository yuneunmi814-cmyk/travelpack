{
  "name": "travelpack-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "keys:gen": "tsx scripts/generate-keys.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:prod": "tsx prisma/seed-prod.ts",
    "db:studio": "prisma studio",
    "sync:tourapi": "tsx scripts/sync-tourapi.ts",
    "sync:audioguide": "tsx scripts/sync-audioguide.ts",
    "sync:photos": "tsx scripts/sync-enrich.ts photos",
    "sync:i18n": "tsx scripts/sync-enrich.ts i18n",
    "sync:visitors": "tsx scripts/sync-enrich.ts visitors",
    "sync:tourism": "tsx scripts/sync-tourism.ts",
    "sync:youtube": "tsx scripts/sync-youtube.ts",
    "purge": "tsx scripts/purge.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@prisma/client": "^6.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.8.0",
    "prisma-erd-generator": "^2.4.3",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
