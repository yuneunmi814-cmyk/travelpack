// TravelPack DB 스키마 — docs/TravelPack_기획설계서.md 2.3절 기준 (20개 테이블)
generator client {
  provider = "prisma-client-js"
}

// 스키마에서 ERD 자동 생성(Mermaid 마크다운) — `prisma generate` 시 docs/erd.md 갱신.
// md 출력이라 mermaid-cli/Chromium 불필요. 배포(Docker)에서는 DISABLE_ERD=true로 건너뜀.
generator erd {
  provider                  = "prisma-erd-generator"
  output                    = "../../docs/erd.md"
  includeRelationFromFields = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum AuthProvider {
  local
  kakao
  google
}

enum ConsentType {
  TERMS
  PRIVACY
  AGE14
  LOCATION
  MARKETING
  NIGHT_PUSH
}

enum CourseAuthorType {
  EDITOR
  USER
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum SpotStatus {
  ACTIVE
  INACTIVE
}

enum BookmarkTarget {
  COURSE
  SPOT
}

enum TransportType {
  WALK
  BUS
  TAXI
  CAR
}

enum TripStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELED
}

enum VisitStatus {
  PENDING
  DONE
  SKIPPED
}

enum CheckinType {
  VERIFIED
  MANUAL
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum ReportStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_MANAGER
  OPERATION_MANAGER
  MARKETER
  READ_ONLY
}

model User {
  id           BigInt       @id @default(autoincrement())
  email        String?      @unique
  passwordHash String?      @map("password_hash")
  nickname     String       @unique
  provider     AuthProvider @default(local)
  providerId   String?      @map("provider_id")
  profileImageUrl String?   @map("profile_image_url")
  status       UserStatus   @default(ACTIVE)
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  consents   UserConsent[]
  interests  UserInterest[]
  pushTokens UserPushToken[]
  bookmarks  Bookmark[]
  trips      Trip[]
  reviews    Review[]
  reports    ReviewReport[]
  authoredCourses Course[]        @relation("authoredCourses")
  purchases       CoursePurchase[]

  @@unique([provider, providerId])
  @@map("users")
}

model UserConsent {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt      @map("user_id")
  consentType ConsentType @map("consent_type")
  agreed      Boolean
  version     String
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, createdAt])
  @@map("user_consents")
}

model UserInterest {
  userId  BigInt @map("user_id")
  themeId BigInt @map("theme_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([userId, themeId])
  @@map("user_interests")
}

model UserPushToken {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  fcmToken    String   @unique @map("fcm_token")
  deviceModel String?  @map("device_model")
  osVersion   String?  @map("os_version")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_push_tokens")
}

model Region {
  id           BigInt  @id @default(autoincrement())
  name         String  @unique
  slug         String  @unique
  thumbnailUrl String? @map("thumbnail_url")
  sortOrder    Int     @default(0) @map("sort_order")
  isActive     Boolean @default(true) @map("is_active")
  /// 관광 빅데이터(지역별 방문자수) 기반 인기 점수 — 최근 외지인+외국인 합. 인기 정렬·배지용
  visitorScore Int     @default(0) @map("visitor_score")
  /// 유튜브 여행영상 화제도(상위 영상 조회수 기반) — '요즘 뜨는 곳' 추천 랭킹용
  buzzScore    Int     @default(0) @map("buzz_score")

  spots   Spot[]
  courses Course[]
  videos  Video[]

  @@map("regions")
}

model Theme {
  id   BigInt @id @default(autoincrement())
  name String @unique
  icon String?

  courseThemes CourseTheme[]
  interests    UserInterest[]

  @@map("themes")
}

model Spot {
  id              BigInt     @id @default(autoincrement())
  regionId        BigInt     @map("region_id")
  name            String
  category        String
  summary         String?
  description     String?
  tips            String?
  address         String?
  lat             Float
  lng             Float
  /// PostGIS — 반경 검색용. lat/lng 변경 시 트리거가 자동 동기화
  location        Unsupported("geography(Point, 4326)")?
  openHours       Json?      @map("open_hours")
  admissionFee    String?    @map("admission_fee")
  avgStayMinutes  Int?       @map("avg_stay_minutes")
  phone           String?
  status          SpotStatus @default(ACTIVE)
  checkinRadiusM  Int?       @map("checkin_radius_m")
  source          String     @default("EDITOR")
  tourapiContentId String?   @unique @map("tourapi_content_id")
  petInfo         Json?      @map("pet_info")       // 반려동물 동반여행(TourAPI detailPetTour2)
  barrierFree     Json?      @map("barrier_free")   // 무장애 여행(TourAPI detailWithTour2)
  relatedSpots    Json?      @map("related_spots")  // 연관 관광지(데이터랩 TarRlteTar, [{name,category,rank}])
  petFriendly     Boolean    @default(false) @map("pet_friendly")  // 필터용 플래그
  hasBarrierFree  Boolean    @default(false) @map("has_barrier_free")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  region       Region            @relation(fields: [regionId], references: [id])
  images       SpotImage[]
  courseItems  CourseItem[]
  audioGuides  AudioGuide[]
  translations SpotTranslation[]
  videos       Video[]

  @@index([regionId, status])
  @@map("spots")
}

// 다국어 번역(영문 등) — EngService2의 동일 contentId로 적재
model SpotTranslation {
  id          BigInt   @id @default(autoincrement())
  spotId      BigInt   @map("spot_id")
  langCode    String   @map("lang_code")
  name        String
  summary     String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([spotId, langCode])
  @@map("spot_translations")
}

// 한국관광공사 관광지 오디오 가이드(오디·Odii). 스팟에 좌표 근접 매칭으로 연결.
model AudioGuide {
  id           BigInt   @id @default(autoincrement())
  spotId       BigInt   @map("spot_id")
  source       String   @default("ODII")
  odiiThemeId  String   @map("odii_theme_id")  // tid
  odiiStoryId  String   @map("odii_story_id")  // stid
  langCode     String   @map("lang_code")
  title        String
  audioTitle   String?  @map("audio_title")
  script       String?
  audioUrl     String?  @map("audio_url")
  imageUrl     String?  @map("image_url")
  playTime     Int?     @map("play_time")
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([spotId, odiiStoryId, langCode])
  @@index([spotId, langCode])
  @@map("audio_guides")
}

model SpotImage {
  id        BigInt @id @default(autoincrement())
  spotId    BigInt @map("spot_id")
  url       String
  sourceCredit String? @map("source_credit")
  source    String  @default("EDITOR")          // EDITOR / TOURAPI / PHOTO(관광사진)
  sourceId  String? @map("source_id")            // 외부 식별자(galContentId 등) — 멱등 dedupe
  sortOrder Int    @default(0) @map("sort_order")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([spotId, sourceId])
  @@map("spot_images")
}

/// 유튜브 여행영상(쇼츠 등 짧은 영상) — YouTube Data API v3로 수집. 지역(필수)·스팟(선택) 연결.
/// 홈 '여행 쇼츠' 피드·코스/스팟 상세 임베드·지역 화제도(buzzScore) 산출에 사용.
model Video {
  id           BigInt    @id @default(autoincrement())
  youtubeId    String    @unique @map("youtube_id")
  title        String
  channelTitle String?   @map("channel_title")
  thumbnailUrl String?   @map("thumbnail_url")
  viewCount    BigInt    @default(0) @map("view_count")
  publishedAt  DateTime? @map("published_at")
  durationSec  Int?      @map("duration_sec")
  regionId     BigInt?   @map("region_id")
  spotId       BigInt?   @map("spot_id")
  sortOrder    Int       @default(0) @map("sort_order")  // 지역 내 노출 순서(조회수 desc)
  createdAt    DateTime  @default(now()) @map("created_at")

  region Region? @relation(fields: [regionId], references: [id], onDelete: Cascade)
  spot   Spot?   @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@index([regionId, sortOrder])
  @@index([spotId, sortOrder])
  @@map("videos")
}

model Course {
  id            BigInt        @id @default(autoincrement())
  regionId      BigInt        @map("region_id")
  title         String
  summary       String?
  durationDays  Int           @map("duration_days")
  estCost       Int?          @map("est_cost")
  coverImageUrl String?       @map("cover_image_url")
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?     @map("published_at")
  viewCount     Int           @default(0) @map("view_count")
  saveCount     Int           @default(0) @map("save_count")
  createdBy     BigInt?       @map("created_by")    // 에디터(관리자) 작성 시
  source        String        @default("EDITOR")
  tourapiContentId String?    @unique @map("tourapi_content_id")
  // 크리에이터 마켓플레이스
  authorType    CourseAuthorType @default(EDITOR) @map("author_type")
  authorUserId  BigInt?       @map("author_user_id")  // 사용자(크리에이터) 작성 시
  price         Int           @default(0)              // KRW, 0 = 무료
  salesCount    Int           @default(0) @map("sales_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  region     Region          @relation(fields: [regionId], references: [id])
  creator    AdminUser?      @relation(fields: [createdBy], references: [id])
  author     User?           @relation("authoredCourses", fields: [authorUserId], references: [id])
  themes     CourseTheme[]
  items      CourseItem[]
  trips      Trip[]
  purchases  CoursePurchase[]

  @@index([status, regionId])
  @@index([status, saveCount, id])
  @@index([authorType, status, id])
  @@map("courses")
}

enum PurchaseStatus {
  PENDING
  PAID
  REFUNDED
}

// 코스 구매 이용권(entitlement). 무료 코스는 구매 없이 접근.
model CoursePurchase {
  id          BigInt         @id @default(autoincrement())
  courseId    BigInt         @map("course_id")
  userId      BigInt         @map("user_id")
  price       Int            // 구매 시점 가격(원)
  status      PurchaseStatus @default(PENDING)
  provider    String?        // PG사(portone/toss…) — 무료는 null
  paymentId   String?        @unique @map("payment_id")  // PG 거래 식별자(유니크 — 동일 거래 중복/오매칭 방지)
  purchasedAt DateTime?      @map("purchased_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId, status])
  @@map("course_purchases")
}

model CourseTheme {
  courseId BigInt @map("course_id")
  themeId  BigInt @map("theme_id")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  theme  Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([courseId, themeId])
  @@map("course_themes")
}

model CourseItem {
  id               BigInt         @id @default(autoincrement())
  courseId         BigInt         @map("course_id")
  dayNo            Int            @map("day_no")
  sortOrder        Int            @map("sort_order")
  spotId           BigInt         @map("spot_id")
  stayMinutes      Int?           @map("stay_minutes")
  transportToNext  TransportType? @map("transport_to_next")
  transportMinutes Int?           @map("transport_minutes")
  note             String?

  course Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  spot   Spot        @relation(fields: [spotId], references: [id])
  visits TripVisit[]

  @@unique([courseId, dayNo, sortOrder])
  @@map("course_items")
}

model Bookmark {
  id         BigInt         @id @default(autoincrement())
  userId     BigInt         @map("user_id")
  targetType BookmarkTarget @map("target_type")
  targetId   BigInt         @map("target_id")
  createdAt  DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@map("bookmarks")
}

model Trip {
  id        BigInt     @id @default(autoincrement())
  userId    BigInt     @map("user_id")
  courseId  BigInt     @map("course_id")
  startDate DateTime   @map("start_date") @db.Date
  endDate   DateTime   @map("end_date") @db.Date
  status    TripStatus @default(UPCOMING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course      @relation(fields: [courseId], references: [id])
  visits TripVisit[]

  @@index([userId, status])
  @@map("trips")
}

model TripVisit {
  id              BigInt       @id @default(autoincrement())
  tripId          BigInt       @map("trip_id")
  courseItemId    BigInt       @map("course_item_id")
  status          VisitStatus  @default(PENDING)
  checkedInAt     DateTime?    @map("checked_in_at")
  /// 체크인 좌표 — 6개월 후 배치 NULL 처리 (위치정보 최소 보관)
  checkinLocation Unsupported("geography(Point, 4326)")? @map("checkin_location")
  checkinType     CheckinType? @map("checkin_type")

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  courseItem CourseItem @relation(fields: [courseItemId], references: [id])

  @@unique([tripId, courseItemId])
  @@map("trip_visits")
}

model Review {
  id         BigInt         @id @default(autoincrement())
  userId     BigInt         @map("user_id")
  targetType BookmarkTarget @map("target_type")
  targetId   BigInt         @map("target_id")
  tripId     BigInt?        @map("trip_id")
  rating     Int
  content    String
  status     ReviewStatus   @default(VISIBLE)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  images  ReviewImage[]
  reports ReviewReport[]

  @@index([targetType, targetId, status])
  @@map("reviews")
}

model ReviewImage {
  id       BigInt @id @default(autoincrement())
  reviewId BigInt @map("review_id")
  url      String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model ReviewReport {
  id          BigInt       @id @default(autoincrement())
  reviewId    BigInt       @map("review_id")
  reporterId  BigInt       @map("reporter_id")
  reasonCode  String       @map("reason_code")
  detail      String?
  status      ReportStatus @default(PENDING)
  processedBy BigInt?      @map("processed_by")
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id])

  @@unique([reviewId, reporterId])
  @@map("review_reports")
}

model Banner {
  id         BigInt   @id @default(autoincrement())
  title      String
  imageUrl   String   @map("image_url")
  linkType   String   @map("link_type")
  linkTarget String?  @map("link_target")
  startAt    DateTime @map("start_at")
  endAt      DateTime @map("end_at")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")

  @@map("banners")
}

model AdminUser {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole
  totpSecret   String?   @map("totp_secret")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  courses   Course[]
  auditLogs AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  adminId    BigInt   @map("admin_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
