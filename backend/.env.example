# 서버
PORT=4000
NODE_ENV=development

# DB (PostgreSQL 16+ with PostGIS)
DATABASE_URL=postgresql://yoon@localhost:5432/travelpack_dev
TEST_DATABASE_URL=postgresql://yoon@localhost:5432/travelpack_test

# Redis — 비우면 인메모리 드라이버로 동작 (개발/테스트 전용. 운영은 필수)
REDIS_URL=

# JWT RS256 키 경로 (npm run keys:gen 으로 생성)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
ACCESS_TOKEN_TTL_SEC=1800
REFRESH_TOKEN_TTL_DAYS=14

# bcrypt cost (운영 12 고정, 테스트는 4로 단축)
BCRYPT_ROUNDS=12

# 소셜 로그인 (선택 — 비우면 /auth/social 503)
GOOGLE_CLIENT_ID=
KAKAO_ENABLED=true

# 한국관광공사 TourAPI — 공공데이터포털 발급 serviceKey(디코딩 키 그대로). 비우면 sync:tourapi 비활성
TOURAPI_SERVICE_KEY=

# S3 업로드 — 비우면 /uploads/presigned-url 503. 자격증명은 표준 AWS 체인(환경변수/프로파일/IAM)
AWS_REGION=ap-northeast-2
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# FCM 푸시 — 비우면 캠페인 발송은 수신자 집계만(no-op)
FCM_PROJECT_ID=

# 마켓플레이스 결제 PG — 둘 다 채워야 유료 코스 구매 활성(무료 코스는 항상 정상). 비우면 유료 구매 503
PG_PROVIDER=
PG_API_SECRET=
# 플랫폼 수수료율(%) — 정산 시 크리에이터 몫 = 가격 × (1 − 수수료율). 기본 20
MARKETPLACE_FEE_PERCENT=20

# 시드 관리자 초기 비밀번호
SEED_ADMIN_PASSWORD=travelpack-dev-1234
