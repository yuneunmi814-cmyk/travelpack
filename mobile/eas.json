{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://travelpack-api.onrender.com/api/v1",
        "EXPO_PUBLIC_LEGAL_BASE_URL": "https://travelpack-legal.netlify.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle" },
      "ios": {},
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://travelpack-api.onrender.com/api/v1",
        "EXPO_PUBLIC_LEGAL_BASE_URL": "https://travelpack-legal.netlify.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
